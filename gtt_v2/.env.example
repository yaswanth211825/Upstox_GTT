# ── Database ──────────────────────────────────────────────────────────────────
POSTGRES_DSN=postgres://postgres:changeme@localhost:5432/gtt_trading?sslmode=disable

# ── Redis ────────────────────────────────────────────────────────────────────
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_STREAM_NAME=raw_trade_signals

# ── Upstox ───────────────────────────────────────────────────────────────────
UPSTOX_ACCESS_TOKEN=
UPSTOX_BASE_URL=https://api.upstox.com

# ── Lot sizes ────────────────────────────────────────────────────────────────
LOT_SIZE_NIFTY=75
LOT_SIZE_BANKNIFTY=15
LOT_SIZE_SENSEX=20
DEFAULT_QUANTITY=1

# ── Trading Floor rules ───────────────────────────────────────────────────────
BUFFER_SL_PTS=2.5
BUFFER_TARGET_PTS=6.0
DAILY_PNL_LIMIT_PCT=0.10
ACCOUNT_CAPITAL=100000
TRADER_PROFILE=SAFE           # SAFE or RISK
GTT_EXPIRY_HOURS=6

# ── Telegram ─────────────────────────────────────────────────────────────────
TELEGRAM_API_ID=
TELEGRAM_API_HASH=
TELEGRAM_PHONE=
GROUP_ENTITY_NAME=MS-OPTIONS-PREMIUM

# ── AI ────────────────────────────────────────────────────────────────────────
AI_PROVIDER=GEMINI            # GEMINI or OPENAI
GEMINI_API_KEY=
AI_MODEL=gemini-2.0-flash-lite

# ── Ops ────────────────────────────────────────────────────────────────────────
DRY_RUN=false
LOG_LEVEL=INFO
