# ============================================================
# Upstox GTT Strategy - Environment Template
# Copy this file to .env and fill in your values
# ============================================================

# ---------------------------
# Upstox API
# ---------------------------
UPSTOX_ACCESS_TOKEN=your_upstox_access_token_here
UPSTOX_BASE_URL=https://api.upstox.com

# ---------------------------
# Redis
# ---------------------------
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_STREAM_NAME=raw_trade_signals

# resume | $ | 0
REDIS_START_FROM=resume

# ---------------------------
# Deduplication / Tracking
# ---------------------------
PROCESSED_GTT_ZSET=processed_gtt_signals
LAST_GTT_ID_KEY=processed_gtt:last_id
PROCESSED_ZSET_MAX=10000

# ---------------------------
# Order Defaults
# ---------------------------
# Default number of lots when signal doesn't specify quantity
DEFAULT_QUANTITY=1

# Force strict Telegram template parsing when using raw message mode
STRICT_TEMPLATE_ENABLED=true
SIGNAL_TEMPLATE_DELIMITER=|

# Optional lot-size overrides by underlying / option type
# If set, these take priority over Upstox instrument metadata
LOT_SIZE_SENSEX_CE=20
LOT_SIZE_SENSEX_PE=20
LOT_SIZE_BANKNIFTY_CE=35
LOT_SIZE_BANKNIFTY_PE=35
LOT_SIZE_NIFTY_CE=75
LOT_SIZE_NIFTY_PE=75
