# ============================================================
# Unified Telegram -> Redis -> Upstox GTT Configuration
# ============================================================

# ---------------------------
# Telegram
# ---------------------------
TELEGRAM_API_ID=your_telegram_api_id
TELEGRAM_API_HASH=your_telegram_api_hash
TELEGRAM_PHONE=+910000000000
GROUP_ENTITY_NAME=MS-OPTIONS-PREMIUM

# ---------------------------
# AI Parser
# ---------------------------
# GEMINI | OPENAI
AI_PROVIDER=GEMINI
GEMINI_API_KEY=your_gemini_api_key
OPENAI_API_KEY=your_openai_api_key
# Optional override
AI_MODEL=
LOG_LEVEL=INFO

# ---------------------------
# Upstox API
# ---------------------------
UPSTOX_ACCESS_TOKEN=your_upstox_access_token_here
UPSTOX_BASE_URL=https://api.upstox.com

# ---------------------------
# Redis
# ---------------------------
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_STREAM_NAME=raw_trade_signals
REDIS_STREAM_KEY=raw_trade_signals

# Listener dedupe
REDIS_DEDUPE_KEY=processed_signals_zset
REDIS_MAX_DEDUPE=5000

# Consumer start mode: resume | $ | 0
REDIS_START_FROM=resume

# Consumer dedupe / resume
PROCESSED_GTT_ZSET=processed_gtt_signals
LAST_GTT_ID_KEY=processed_gtt:last_id
PROCESSED_ZSET_MAX=10000

# ---------------------------
# Order Defaults
# ---------------------------
DEFAULT_QUANTITY=1
STRICT_TEMPLATE_ENABLED=true
SIGNAL_TEMPLATE_DELIMITER=|
PRINT_DEBUG=false

# ---------------------------
# Process mode
# ---------------------------
# web -> browser form -> Redis -> strategy
# telegram -> Telegram listener -> AI parser -> Redis -> strategy
PROCESS_MODE=web

# ---------------------------
# Low-latency strategy tuning
# ---------------------------
# Use persistent HTTP connection pool for Upstox placement.
USE_POOLED_HTTP_POST=true
HTTP_POOL_CONNECTIONS=30
HTTP_POOL_MAXSIZE=60

# Keep LTP fetch out of placement hot path by default.
FETCH_LTP_AFTER_PLACEMENT=false

# Persist Redis/SQLite metadata after placement using background worker.
ASYNC_METADATA_WRITE=true

# Optional lot-size overrides
LOT_SIZE_SENSEX_CE=20
LOT_SIZE_SENSEX_PE=20
LOT_SIZE_BANKNIFTY_CE=35
LOT_SIZE_BANKNIFTY_PE=35
LOT_SIZE_NIFTY_CE=75
LOT_SIZE_NIFTY_PE=75

# ---------------------------
# Optional webhook forwarding
# ---------------------------
OPENALGO_WEBHOOK_URL=
OPENALGO_API_KEY=

# ---------------------------
# Frontend signal bridge (Telegram/AI bypass)
# ---------------------------
# Local HTTP endpoint used by your frontend to submit already-structured signals.
FRONTEND_BIND_HOST=127.0.0.1
FRONTEND_BIND_PORT=8787

# Optional bearer token protection for /signal endpoint.
FRONTEND_AUTH_TOKEN=

# ---------------------------
# Tracker / recovery
# ---------------------------
TRACKER_RECONCILE_INTERVAL=120
